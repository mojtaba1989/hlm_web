{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Backend",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "env": {
                "FLASK_ENV": "development"
            },
            "args": [
                "main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ]
        },
        {
            "name": "Frontend",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/frontend",
        },
        {
            "name": "Debug rec",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tests/rec",
            "args": [],                 // command-line args if needed
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "preLaunchTask": "build rec"
        }
    ],
    "compounds": [
        {
            "name": "Run Backend + Frontend",
            "configurations": ["Backend", "Frontend"]
        }
    ]
}
